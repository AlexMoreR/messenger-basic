{
  "manifest_version": 3,
  "name": "NETMAGI (Basic)",
  "version": "2.12.0",
  "description": "Aplicacion de automatizacion",
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.facebook.com/*",
    "https://script.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.facebook.com/*"
      ],
      "js": ["ui.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": { "default_title": "NETMAGI Replies" }
}
